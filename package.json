{
  "name": "nexus-browser",
  "version": "0.1.0",
  "description": "AI-native web browser with Hexagonal Architecture",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev:next": "next dev -p 3000",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p tsconfig.electron.json && electron .",
    "dev": "concurrently -k \"npm run dev:next\" \"npm run dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:next && npm run build:electron",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "dotenv": "^17.3.1",
    "next": "^15.5.12",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
